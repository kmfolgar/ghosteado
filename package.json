{
  "name": "ghosteado",
  "displayName": "Ghosteado",
  "description": "Container-first data protection for VS Code workspaces. Externalizes real datasets, preserves stable host paths, captures safe schema summaries, and mounts synthetic workspaces into devcontainers when needed.",
  "version": "1.0.0",
  "author": "Kevin Martinez-Folgar",
  "publisher": "KevinMF",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["privacy", "ai", "copilot", "data protection", "research", "docker", "devcontainer"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghosteado.protectFolder",
        "title": "👻 Ghosteado: Protect This Dataset"
      },
      {
        "command": "ghosteado.unprotectFolder",
        "title": "🔓 Ghosteado: Remove Data Protection"
      },
      {
        "command": "ghosteado.showStatus",
        "title": "Ghosteado: Show Protected Workspace Status"
      },
      {
        "command": "ghosteado.viewSchema",
        "title": "Ghosteado: View Schema"
      },
      {
        "command": "ghosteado.copySimulationPrompt",
        "title": "Ghosteado: Copy Simulation Prompt"
      },
      {
        "command": "ghosteado.clearLog",
        "title": "Ghosteado: Clear Access Log"
      },
      {
        "command": "ghosteado.regenerateSimulated",
        "title": "Ghosteado: Prepare Synthetic Data Prompt"
      },
      {
        "command": "ghosteado.setupWizard",
        "title": "👻 Ghosteado: Data Protection Setup Wizard"
      },
      {
        "command": "ghosteado.addContainerProtection",
        "title": "🐳 Ghosteado: Refresh Container Protection"
      },
      {
        "command": "ghosteado.resumeProtectedWorkspace",
        "title": "Ghosteado: Resume Protected Workspace"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ghosteado.protectFolder",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@1"
        },
        {
          "command": "ghosteado.unprotectFolder",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@2"
        }
      ]
    },
    "configuration": {
      "title": "Ghosteado",
      "properties": {
        "ghosteado.protectedFolders": {
          "type": "array",
          "default": [],
          "description": "Workspace dataset paths that should warn if opened on the host instead of inside the container.",
          "items": { "type": "string" }
        },
        "ghosteado.simulatedRowCount": {
          "type": "number",
          "default": 20,
          "description": "Default row count to include when generating synthetic data prompts."
        },
        "ghosteado.simulatedSeed": {
          "type": "number",
          "default": 42,
          "description": "Reserved for future synthetic data helpers."
        },
        "ghosteado.notifyOnBlock": {
          "type": "string",
          "enum": ["statusBar", "notification", "both"],
          "default": "both",
          "description": "How to alert you when a protected dataset path is opened on the host."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
