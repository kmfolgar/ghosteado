{
  "name": "ghosteado",
  "displayName": "Ghosteado",
  "description": "Ghosts sensitive data folders from AI agents. Blocks access, logs attempts, generates safe simulated datasets, and creates isolated devcontainers.",
  "version": "0.9.0",
  "author": "Kevin Martinez-Folgar",
  "publisher": "KevinMF",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["privacy", "ai", "copilot", "data protection", "research", "docker", "devcontainer"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghosteado.protectFolder",
        "title": "👻 Ghosteado: Ghost This Folder"
      },
      {
        "command": "ghosteado.unprotectFolder",
        "title": "🔓 Ghosteado: Remove Ghost"
      },
      {
        "command": "ghosteado.showStatus",
        "title": "Ghosteado: Show Status & Access Log"
      },
      {
        "command": "ghosteado.clearLog",
        "title": "Ghosteado: Clear Access Log"
      },
      {
        "command": "ghosteado.regenerateSimulated",
        "title": "Ghosteado: Regenerate Simulated Data"
      },
      {
        "command": "ghosteado.setupWizard",
        "title": "👻 Ghosteado: Data Protection Setup Wizard"
      },
      {
        "command": "ghosteado.addContainerProtection",
        "title": "🐳 Ghosteado: Add Container Protection"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ghosteado.protectFolder",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@1"
        },
        {
          "command": "ghosteado.unprotectFolder",
          "when": "explorerResourceIsFolder",
          "group": "7_modification@2"
        }
      ]
    },
    "configuration": {
      "title": "Ghosteado",
      "properties": {
        "ghosteado.protectedFolders": {
          "type": "array",
          "default": [],
          "description": "Folder paths currently ghosted from AI agents.",
          "items": { "type": "string" }
        },
        "ghosteado.simulatedRowCount": {
          "type": "number",
          "default": 20,
          "description": "Rows to generate in simulated CSV datasets."
        },
        "ghosteado.simulatedSeed": {
          "type": "number",
          "default": 42,
          "description": "Seed for deterministic fake data generation."
        },
        "ghosteado.notifyOnBlock": {
          "type": "string",
          "enum": ["statusBar", "notification", "both"],
          "default": "both",
          "description": "How to alert you when a blocked read is attempted."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
